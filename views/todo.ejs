<!-- Declares this document as HTML5. -->
<!DOCTYPE html>

<!-- Starts the head section containing metadata and linked resources. -->

<head>
    <!-- Sets the page title shown in the browser tab. -->
    <title>Todo App</title>
    <!-- Links your local CSS file served from the /static path. -->
    <link rel="stylesheet" href="/static/stylesheets/style.css" type="text/css">
    <!-- Loads Google Fonts used by this page. -->
    <link href="https://fonts.googleapis.com/css?family=Baloo+Bhai|Candal|Chewy&display=swap" rel="stylesheet">
    <!-- Loads Font Awesome icons from a CDN. -->
    <!-- Adds an integrity hash for security verification of the CDN file. -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.8.2/css/all.css"
        integrity="sha384-oS3vJWv+0UjzBfQzYUhtDYW+Pj2yciDJxpsK1OYPAYjqT085Qq/1cq5FLXAZQ7Ay" crossorigin="anonymous">
    <!-- Closes the head section. -->
</head>

<!-- Starts the visible page body. -->

<body>
    <!-- Main wrapper for the todo app layout. -->
    <div class="todo-container">
        <h2>To-Do List</h2>
        <!-- Remaining tasks -->
        <p class="task-counter">
            <%= remaining %> task<%= remaining===1 ? '' : 's' %> remaining.
        </p>
        <!-- Container for form and list content. -->
        <div class="todo">
            <!-- Form submits new todo content to the server using POST /. -->
            <form action="/" method="POST" class="todo-header">
                <!-- Text input where user types a task. -->
                <input type="text" name="content" required minlength="1" placeholder="Add Task">
                <select name="category" class="category-select">
                    <option value="general">General</option>
                    <option value="work">Work</option>
                    <option value="personal">Personal</option>
                    <option value="study">Study</option>
                </select>
                <input type="date" name="dueDate" class="due-date-input">
                <!-- Submit button with plus icon to add a task. -->
                <button type="submit"><span class="fas fa-plus"></span></button>
                <!-- Closes the form. -->
            </form>

            <!-- Filter by status -->
            <div class="filter-btns">
                <a href="/?filter=All" class="filter-btn <%= activeFilter === 'All' ? 'active' : '' %>">All</a>
                <a href="/?filter=Active" class="filter-btn <%= activeFilter === 'Active' ? 'active' : '' %>">Active</a>
                <a href="/?filter=Completed" class="filter-btn <%= activeFilter === 'Completed' ? 'active' : '' %>">Completed</a>
            </div>

            <!-- Sort by date -->
            <div class="sort-btns">
                <a href="/?sort=newest" class="sort-btn" <%=sortOrder.date===-1 ? ' active' : '' %>>Newest</a>
                <a href="/?sort=oldest" class="sort-btn" <%=sortOrder.date===1 ? ' active' : '' %>>Oldest</a>
            </div>

            <!-- Starts unordered list that displays all todo items. -->
            <ul class="todo-list">
                <%# Loops through each todo item passed from the server. %>
                    <% todoTasks.forEach(details=> { %>
                        <!-- One list item for each task. -->
                        <li class="todo-list-item <%= details.completed ? 'done' : '' %>">

                            <%# This one visually indicates if the task is completed or not by showing a check icon and
                                applying styles. %>
                                <form action="/complete/<%= details._id %>" method="POST" class="check-form">
                                    <button type="submit" class="check-btn <%= details.completed ? 'checked' : '' %>">
                                        <span
                                            class="fas <%= details.completed ? 'fa-check-circle' : 'fa-circle' %>"></span>
                                    </button>
                                </form>
                                <div class="todo-list-item-name <%= details.completed ? 'strikethrough' : '' %>">
                                    <%= details.content %>
                                </div>
                                <!-- Filter by category -->
                                <span class="category-badge category-<%= details.category%>">
                                    <%= details.category %>
                                </span>
                                <!-- Show due date if it exists -->
                                <% if (details.dueDate) { %>
                                    <span class="due-date">
                                        Due: <%= details.dueDate.toLocaleDateString() %>
                                    </span>
                                <% } %>
                                <!-- Link to edit this specific task using its MongoDB id. -->
                                <a href="/edit/<%= details._id %>" class="edit">
                                    <!-- Edit icon. -->
                                    <span class="fas fa-edit"></span>
                                    <!-- Closes edit link. -->
                                </a>
                                <!-- Link to remove this specific task using its MongoDB id. -->
                                <a href="#" class="remove" onclick="confirmdelete('<%= details._id %>')">
                                    <!-- Remove icon. -->
                                    <span class="fas fa-times"></span>
                                    <!-- Closes remove link. -->
                                </a>
                                <!-- Closes one task list item. -->
                        </li>
                        <%# Ends the forEach loop over todo tasks. %>
                            <% }) %>
                                <!-- Closes the unordered todo list. -->
            </ul>
            <!-- Closes the inner todo container. -->
        </div>
        <!-- Closes the main todo container. -->
    </div>
    <!-- Closes the page body. -->
    <div id="delete-overlay" style="display: none;">
        <div class="delete-dialog">
            <p>Are you sure you want to delete this task?</p>
            <button id="confirm-delete-btn">Yes</button>
            <button id="cancel-delete-btn" onclick="canceldelete()">No</button>
        </div>
    </div>
</body>

<!-- JavaScript function to confirm deletion of a task. -->
<script>
    function confirmdelete(id) {
        document.getElementById('delete-overlay').style.display = 'flex';
        document.getElementById('confirm-delete-btn').onclick = function () {
            window.location.href = '/remove/' + id;
        };
    }
    function canceldelete() {
        document.getElementById('delete-overlay').style.display = 'none';
    }
</script>